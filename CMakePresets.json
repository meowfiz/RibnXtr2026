{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },

  "configurePresets": [
    {
      "name": "vs2019-x64",
      "displayName": "VS2019 x64 (multi-config)",
      "generator": "Visual Studio 16 2019",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build-vs2019",
      "cacheVariables": {
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/deps.cmake"
      }
    },
    {
      "name": "vs2022-x64",
      "displayName": "VS2022 x64 (multi-config)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build-vs2022",
      "cacheVariables": {
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/deps.cmake"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "vs2019-debug",
      "configurePreset": "vs2019-x64",
      "configuration": "Debug",
      "jobs": 0
    },
    {
      "name": "vs2019-release",
      "configurePreset": "vs2019-x64",
      "configuration": "Release",
      "jobs": 0
    },
    {
      "name": "vs2022-debug",
      "configurePreset": "vs2022-x64",
      "configuration": "Debug",
      "jobs": 0
    },
    {
      "name": "vs2022-release",
      "configurePreset": "vs2022-x64",
      "configuration": "Release",
      "jobs": 0
    }
  ]
}